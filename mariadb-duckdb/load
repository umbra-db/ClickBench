#!/bin/bash
set -eu

# Helper: run a DuckDB SQL statement through MariaDB's run_in_duckdb UDF.
# Single quotes inside $1 are doubled so they survive the MariaDB string literal.
duck() {
    local esc
    esc=$(printf '%s' "$1" | sed "s/'/''/g")
    sudo mariadb -N -e "SELECT run_in_duckdb('$esc')"
}

sudo mariadb -e "DROP DATABASE IF EXISTS test"
sudo mariadb -e "CREATE DATABASE test"
sudo mariadb test < create.sql

# Load via DuckDB's native vectorized CSV reader (12x faster than LOAD DATA LOCAL
# INFILE which routes every row through MariaDB's single-threaded write_row path).
# hits.tsv is tab-delimited with datetime strings in TIMESTAMP columns, matching
# the table schema — no type conversion needed.
#
# DuckDB glob expander requires read permission on all parent directories.
# /home/ubuntu is mode 751 (o+x only) so DuckDB can traverse but not list it,
# causing "No files found" errors. Hardlink to /var/lib/mysql/ (mysql-owned,
# mode 755) resolves this instantly without copying 70 GB.
HITS_LINK=/var/lib/mysql/hits_load.tsv
sudo ln "$(realpath hits.tsv)" "$HITS_LINK"
sudo chmod 644 "$HITS_LINK"
# NULLSTR '\N' matches MySQL/MariaDB convention: only \N is NULL, empty fields → ''.
# Without this, DuckDB treats every empty TSV field as NULL → NOT NULL violations.
duck "COPY test.hits FROM '$HITS_LINK' (FORMAT CSV, DELIMITER '\t', NULLSTR '\N')"

sudo rm -f "$HITS_LINK"
rm -f hits.tsv
sync
