#!/bin/bash
set -eu

source ../local-env.sh

# hits.parquet is fetched by ./install (outside this timed ./load step) into
# data/. Both create files create the table and ingest in one script. Use
# ON_ERROR_STOP=1 so a mid-load failure (e.g. the box runs out of memory
# and Umbra survives but the transaction errored) bubbles up instead of
# leaving a half-loaded table.
#
# create.sql (Docker) reads /data/hits.parquet from the container's '/data'
# bind mount; create_local.sql reads the host-relative data/hits.parquet
# (the local server's CWD is the umbra dir). Both ingest via umbra.parquetview.
CREATE_FILE=create.sql
[ "$LOCAL" -eq 1 ] && CREATE_FILE=create_local.sql
PGPASSWORD=postgres psql -p 5432 -h 127.0.0.1 -U postgres \
    -v ON_ERROR_STOP=1 -f "$CREATE_FILE"

if [ "$TRACE" -eq 1 ]; then
    mkdir -p "$TRACE_DIR"
    # Zero the stop counter that ./stop bumps to tell the phases apart.
    # ./load runs exactly once, before the query loop, so this is the clean
    # point to reset it — a value left over from a previous run would
    # misclassify every phase. The load's own trace isn't dumped here; the
    # cold-cycle ./stop before query 1 (the first stop) flushes it to
    # load.trace, keeping every dump on the same shutdown boundary.
    echo 0 > "$TRACE_DIR/.stops"
fi

# Row-count check. Umbra has been observed to leave a partial table on memory-
# constrained hosts (the full mmap working set doesn't fit), letting the
# benchmark proceed with implausibly fast timings on the surviving subset.
# ClickBench's hits dataset is exactly 99,997,497 rows.
expected=99997497
got=$(PGPASSWORD=postgres psql -p 5432 -h 127.0.0.1 -U postgres -tAq \
    -c 'SELECT count(*) FROM hits')
if [ "$got" -ne "$expected" ]; then
    echo "umbra/load: hits has $got rows, expected $expected — partial load" >&2
    exit 1
fi

sync
