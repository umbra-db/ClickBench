#!/bin/bash
set -e -o pipefail

if [ ! -x ./clickhouse ]; then
    curl -fsSL --retry 10 --retry-delay 60 --retry-all-errors https://clickhouse.com/ | sh
fi

# Filesystem cache in tmpfs (/dev/shm) for S3 reads: unlike the in-process
# page cache it persists across the per-try clickhouse-local processes, so
# the hot tries read from RAM instead of re-fetching from S3.
#
# max_size must not exceed /dev/shm's capacity, or ClickHouse refuses to
# start (Code 36, BAD_ARGUMENTS) and even ./check's SELECT 1 dies. /dev/shm
# defaults to half of RAM, which is below the 16G we want on every machine
# under 32 GiB, so cap the cache at half of /dev/shm (a quarter of RAM): it
# then always fits and never starves query execution of memory.
#
# Keep the cache in tmpfs on every size rather than spilling to a disk cache
# on the small ones: their local EBS volume is far slower than same-region
# S3, and routing reads through it roughly tripled the datalake runtime.
cache_max=16000000000
shm_bytes=$(df -B1 -P /dev/shm 2>/dev/null | awk 'NR==2 {print $2}')
: "${shm_bytes:=2000000000}"
half_shm=$(( shm_bytes / 2 ))
[ "$half_shm" -lt "$cache_max" ] && cache_max=$half_shm

cat > clickhouse-local.yaml <<YAML
filesystem_caches:
    cache:
        path: '/dev/shm/clickhouse/'
        max_size: $cache_max
YAML
