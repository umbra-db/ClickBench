#!/bin/bash
set -e

clickhouse-client < create.sql

# Symlink the parquet files into user_files, same as ../clickhouse/load.
for f in hits_*.parquet; do
    sudo ln -sf "$PWD/$f" /var/lib/clickhouse/user_files/"$f"
done
sudo chown -h clickhouse:clickhouse /var/lib/clickhouse/user_files/hits_*.parquet

# row_number() OVER (), not rowNumberInAllBlocks(): the latter is per-thread and produces duplicate ids under parallel reads.
clickhouse-client --query "INSERT INTO hits_staging SELECT row_number() OVER () AS id, * FROM file('hits_*.parquet')"

clickhouse-client < split.sql

sudo rm -f /var/lib/clickhouse/user_files/hits_*.parquet
sync
