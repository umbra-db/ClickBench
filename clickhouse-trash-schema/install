#!/bin/bash
set -e

if [ ! -x /usr/bin/clickhouse ]; then
    curl https://clickhouse.com/ | sh
    sudo ./clickhouse install --noninteractive
fi

# Eager startup loading, same as ../clickhouse/install.
sudo mkdir -p /etc/clickhouse-server/config.d
sudo tee /etc/clickhouse-server/config.d/eager_load.yaml >/dev/null <<'EOF'
async_load_databases: false
merge_tree:
  primary_key_lazy_load: 0
  columns_and_secondary_indices_sizes_lazy_calculation: 0
EOF
