#!/bin/bash
set -eu

# Local-object-storage analog of create-bucket: instead of provisioning an AWS
# S3 bucket, start a local MinIO server and create the bucket Umbra uses as its
# (backend=cloud) remote storage. Records the connection details in .s3-env in
# the format `load` sources, and sets the full storage URI as UMBRA_S3_URI —
# the minio://<endpoint>/<bucket>:<region> form (path-style, plaintext) that
# `load` passes straight through (s3:// always resolves to real AWS, so MinIO
# needs the minio:// scheme). Use delete-minio to tear it down.
#
# Mirrors the project's scripts/util/startMinio.sh / .gitlab-ci.yml convention
# (minio/password, 127.0.0.1:9000, region us-east-1). Idempotent: re-running
# reuses a server/bucket that is already up.

here="$(cd "$(dirname "$0")" && pwd)"
envfile="$here/.s3-env"

# --- config (override via env) ---------------------------------------------
user="${MINIO_ROOT_USER:-minio}"
pass="${MINIO_ROOT_PASSWORD:-password}"   # MinIO requires >= 8 chars
bucket="${UMBRA_S3_BUCKET:-umbra}"
region="${UMBRA_S3_REGION:-us-east-1}"
host="${UMBRA_S3_HOST:-127.0.0.1}"
port="${UMBRA_S3_PORT:-9000}"
console_port="${UMBRA_S3_CONSOLE_PORT:-9001}"
endpoint="$host:$port"
data_dir="$here/minio-data"
log="$here/minio.log"

command -v minio >/dev/null 2>&1 || { echo "create-minio: minio binary not found in PATH" >&2; exit 1; }
command -v aws   >/dev/null 2>&1 || { echo "create-minio: aws CLI not found in PATH" >&2; exit 1; }

# --- start the server ------------------------------------------------------
if curl -fsS "http://$endpoint/minio/health/live" >/dev/null 2>&1; then
    echo "create-minio: MinIO already running on $endpoint"
else
    echo "create-minio: starting MinIO on $endpoint (console :$console_port)"
    mkdir -p "$data_dir"
    MINIO_ROOT_USER="$user" MINIO_ROOT_PASSWORD="$pass" \
        nohup minio server "$data_dir" \
            --address ":$port" --console-address ":$console_port" \
            >"$log" 2>&1 &
    for _ in $(seq 1 30); do
        curl -fsS "http://$endpoint/minio/health/live" >/dev/null 2>&1 && break
        sleep 1
    done
    curl -fsS "http://$endpoint/minio/health/live" >/dev/null 2>&1 \
        || { echo "create-minio: MinIO failed to start, see $log" >&2; tail -20 "$log" >&2; exit 1; }
    echo "create-minio: MinIO is up"
fi

# --- create the bucket -----------------------------------------------------
export AWS_ACCESS_KEY_ID="$user" AWS_SECRET_ACCESS_KEY="$pass" AWS_DEFAULT_REGION="$region"
if aws --endpoint-url "http://$endpoint" s3 ls "s3://$bucket" >/dev/null 2>&1; then
    echo "create-minio: bucket s3://$bucket already exists"
else
    aws --endpoint-url "http://$endpoint" s3 mb "s3://$bucket"
    echo "create-minio: created bucket s3://$bucket"
fi

# --- persist (sourced by load) ---------------------------------------------
# UMBRA_S3_URI is the full storage URI load passes through verbatim. Bucket /
# region / endpoint are kept for tooling (data-size etc.); the access keys are
# what create.sql's `with secret` needs.
umask 077
cat > "$envfile" <<EOF
# Generated by create-minio — local MinIO object storage for Umbra.
# Sourced by load. Do not commit. Run delete-minio to clean up.
export UMBRA_S3_URI=minio://$endpoint/$bucket:$region
export UMBRA_S3_BUCKET=$bucket
export UMBRA_S3_REGION=$region
export UMBRA_S3_ENDPOINT=$endpoint
export UMBRA_S3_ACCESS_KEY_ID=$user
export UMBRA_S3_ACCESS_KEY=$pass
EOF
echo "create-minio: done -> $envfile (load sources this for you)."
